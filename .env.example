# Runtime
APP_ENV=development
LOG_LEVEL=INFO
FAKE_MODEL=true

# OpenAI-compatible model adapter
MODEL_PROVIDER=openai
MODEL_NAME=replace-with-supported-model-name
MODEL_BASE_URL=https://api.example.invalid/v1
MODEL_API_KEY=replace-with-local-secret

# Embeddings adapter; may use the same or a different compatible endpoint
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=replace-with-supported-embedding-model
EMBEDDING_BASE_URL=https://api.example.invalid/v1
EMBEDDING_API_KEY=replace-with-local-secret

# Local persistence
DATABASE_URL=sqlite:///./data/planner.db
FAISS_INDEX_PATH=./data/faiss

# Optional LangSmith integration; core tests must work without it
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-poc-planner-local
